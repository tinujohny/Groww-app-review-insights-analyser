# Copy to .env and fill in. Never commit .env.

REVIEW_PULSE_ENVIRONMENT=dev

# Minimum words in the review body (title is ignored). Shorter reviews are dropped.
REVIEW_PULSE_MIN_REVIEW_WORDS=5

# Comma-separated ISO 639-1 codes to keep (e.g. en only). Others are removed in Phase 3.
REVIEW_PULSE_REVIEW_LANGUAGES=en
# If true, drop reviews when language detection is inconclusive; if false, keep them.
# REVIEW_PULSE_STRICT_LANGUAGE_DETECTION=false

# If true, drop reviews whose body contains emoji (Phase 3).
REVIEW_PULSE_DROP_REVIEWS_WITH_EMOJIS=true

# How many reviews you can obtain per export/download with your current tooling.
# Use 500 if the store UI caps exports; increase toward 5000 when the source allows.
REVIEW_PULSE_MAX_REVIEWS_PER_EXPORT=500

# Optional defaults for `review-pulse-collect` (overridable via CLI flags)
# REVIEW_PULSE_APP_STORE_APP_ID=123456789
# REVIEW_PULSE_GOOGLE_PLAY_PACKAGE=com.example.app

# If true, Phase 7 API never scrapes/collects when Phase 2 JSONL is missing (use CSV ingest only).
# REVIEW_PULSE_DISABLE_REMOTE_COLLECT=false

# Groq (Phase 4+)
# REVIEW_PULSE_GROQ_API_KEY=
# REVIEW_PULSE_GROQ_MODEL=llama-3.3-70b-versatile
# Gemini fallback (Phase 4+ when Groq quota/rate-limit is hit)
# REVIEW_PULSE_GEMINI_API_KEY=
# REVIEW_PULSE_GEMINI_MODEL=gemini-1.5-flash

# Email drafts (Phase 6+)
REVIEW_PULSE_EMAIL_PROVIDER=none
# REVIEW_PULSE_EMAIL_USERNAME=you@example.com
# REVIEW_PULSE_EMAIL_PASSWORD=your_app_password
# REVIEW_PULSE_EMAIL_API_KEY=
# REVIEW_PULSE_EMAIL_OAUTH_CLIENT_ID=
# REVIEW_PULSE_EMAIL_OAUTH_CLIENT_SECRET=
# REVIEW_PULSE_EMAIL_DRAFT_TO=you@company.com

# Fee explanation enrichment (Phase 6+)
REVIEW_PULSE_ENABLE_FEE_EXPLANATION=true
REVIEW_PULSE_FEE_SCENARIO=Mutual Fund Exit Load
REVIEW_PULSE_FEE_SOURCE_LINKS=https://groww.in/mutual-funds/amc

# Google doc append (Phase 7+)
REVIEW_PULSE_ENABLE_GOOGLE_DOC_APPEND=true
# REVIEW_PULSE_GOOGLE_DOC_DEFAULT_ID=your_google_doc_id
# Optional MCP bridge command (preferred over direct APIs).
# Placeholders: {doc_id} and {payload_path}
# Example:
# REVIEW_PULSE_GOOGLE_MCP_APPEND_COMMAND=python /path/to/google_mcp_append.py --doc-id {doc_id} --payload {payload_path}
# REVIEW_PULSE_GOOGLE_MCP_TIMEOUT_SECONDS=30

# Phase 7 run timeout guard (seconds) — stale running jobs are auto-marked failed by GET /runs/{runId}.
# REVIEW_PULSE_MAX_RUN_SECONDS=1800
